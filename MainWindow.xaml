<Window x:Class="BreakReminder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BreakReminder"
        mc:Ignorable="d"
        Title="設定 - 休息提醒小幫手" Height="200" Width="300"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Closing="Window_Closing">
    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,20" HorizontalAlignment="Center">
            <TextBlock Text="提醒間隔時間：" VerticalAlignment="Center" FontSize="16" />
            <TextBox x:Name="IntervalTextBox" Width="60" FontSize="16" Padding="4"
                     Text="{Binding ReminderIntervalMinutes, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=LostFocus}"
                     KeyDown="TextBox_KeyDown" />
            <TextBlock Text=" 分鐘" VerticalAlignment="Center" FontSize="16" />
        </StackPanel>

        <Button DockPanel.Dock="Bottom" x:Name="SaveButton" Content="儲存並隱藏" Height="35" FontSize="14" Click="SaveButton_Click"/>
        
        <!-- Empty space in middle -->
        <TextBlock Text="程式會常駐於右下角系統列。&#10;您可以隨時點兩下圖示開啟此設定。" 
                   TextAlignment="Center" Foreground="Gray" VerticalAlignment="Center" />
    </DockPanel>
</Window>
