{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Publish (self-contained single-file)",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "publish",
                "${workspaceFolder}/BreakReminder.csproj",
                "-c", "Release",
                "-r", "win-x64",
                "--self-contained", "true",
                "-p:PublishSingleFile=true",
                "-p:IncludeNativeLibrariesForSelfExtract=true",
                "-p:EnableCompressionInSingleFile=true",
                "-o", "${workspaceFolder}/publish"
            ],
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "Open publish folder",
            "type": "shell",
            "command": "explorer",
            "args": [
                "${workspaceFolder}\\publish"
            ],
            "presentation": {
                "reveal": "never",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Bump version (patch)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}\\build\\bump-version.ps1"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": []
        },
        {
            "label": "Zip publish folder",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}\\build\\zip-publish.ps1"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": []
        },
        {
            "label": "Publish + Open folder",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Bump version (patch)",
                "Publish (self-contained single-file)",
                "Zip publish folder",
                "Open publish folder"
            ],
            "problemMatcher": []
        }
    ]
}
